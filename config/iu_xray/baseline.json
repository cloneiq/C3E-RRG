{
  "data": {
    "dataset_name": "iu_xray",
    "image_dir": "data/iu_xray/images",
    "ann_path": "data/iu_xray/annotation.json",
    "tokenizer": "mix",
    "max_seq_length": 80,
    "threshold": 3,
    "num_workers": 4,
    "batch_size": 8
  },
  "model": {
    "model": "baseline",
    "embed_dim": 512,
    "num_heads": 8,
    "en_num_layers": 3,
    "de_num_layers": 3,
    "ff_dim": 2048,
    "dropout": 0.1,
    "logit_layers": 1
  },
  "sample": {
    "sample_method": "beam_search",
    "beam_size": 5,
    "group_size": 1,
    "sample_n": 1,
    "temperature": 1.0,
    "diversity_lambda": 0.0,
    "length_penalty": "",
    "decoding_constraint": 0,
    "suppress_UNK": 0,
    "output_logsoftmax": 1,
    "bos_idx": 1,
    "eos_idx": 2,
    "pad_idx": 0
  },
  "train": {
    "epochs": 50,
    "save_period": 1,
    "monitor_mode": "max",
    "monitor_metric": "BLEU_4",
    "early_stop": 50,
    "result_dir": "results/iu_xray/baseline",
    "record_dir": "records/iu_xray/baseline"
  },
  "optim": {
    "loss_fn": "lm",
    "optim": "Adam",
    "lr_en": 1e-5,
    "lr_de": 1e-5,
    "weight_decay": 5e-5,
    "amsgrad": true,
    "lr_scheduler": "StepLR",
    "step_size": 10,
    "gamma": 0.1
  },
  "monitor": {
    "monitor_metric_curves": false,
    "display_port": 8099
  },
  "other": {
    "task_name": "finetune_baseline_iuxray",
    "seed": 1234,
    "cuda": 0,
    "task": "inference",
    "resume": "",
    "load_model_path": "results/iu_xray/baseline/model_best.pth"
  }
}
