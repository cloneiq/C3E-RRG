{
    "data": {
        "dataset_name": "iu_xray",
        "image_dir": "data/iu_xray/images",
        "ann_path": "data/iu_xray/annotation.json",
        "tokenizer": "mix",
        "max_seq_length":80,
        "threshold": 3,
        "num_workers": 4,
        "batch_size": 16
    },
    "model": {
        "model": "dymes",
        "embed_dim": 512,
        "v_causal": "n",
        "causal_proj": false,
        "num_heads": 8,
        "en_num_layers": 4,
        "de_num_layers": 4,
        "dropout": 0.1,
        "logit_layers": 1,
        "bos_idx": 0,
        "eos_idx": 0,
        "pad_idx": 0,
        "use_bn": 0,
        "drop_prob_lm": 0.3,

        "enable": true,
        "use_confounder": true,
        "K": 6,
        "alpha_micro": 0.05,
        "use_backward_net": true,
        "ctx_tokens": 4,
        "x_dim": 512,
        "pmi_matrix_path": "pretrain/iu_xray/pmi_matrix_iu_xray.pt",
        "disease_corr_path": "pretrain/iu_xray/disease_corr_iu_xray.npy",
        "normal_template_path": "pretrain/iu_xray/normal_template_iu_xray.npy",
        "lambda_cem": 0.05,
        "lambda_back": 0.05,
        "lambda_cf": 0.03,
        "lambda_fd_ortho": 0.006,
        "cem_proj_dim": 256,
        "cem_nuclear_norm_mode": "schatten_p",
        "cem_schatten_p": 1.0,
        "cem_svd_lowrank_q": 32,
        "cem_use_sv_entropy": false,
        "cem_sv_entropy_weight": 0.5,
        "cem_adaptive_lambda_ent": true,
        "cem_lambda_ent": 0.05,
        "enable_chi": true,
        "grid_hw": 32,
        "chi_save_every": 200,
        "chi_cmap": "jet",
        "chi_save_dir": "",
        "vis_upscale": 2,
        "vis_every": 1,
        "vis_grad_every": 0
    },
    "sample": {
        "sample_method": "beam_search",
        "length_penalty": "",
        "diversity_lambda": 0.5,
        "suppress_UNK": 0,
        "beam_size": 3,
        "temperature": 1.0,
        "sample_n": 1,
        "group_size": 1,
        "output_logsoftmax": 1,
        "decoding_constraint": 0,
        "block_trigrams": 1
    },
    "trainer": {
        "epochs": 50,
        "result_dir": "results/iu_xray/dymes_4",
        "record_dir": "results/iu_xray/dymes_4",
        "save_period": 1,
        "monitor_mode": "max",
        "monitor_metric": "BLEU_4",
        "early_stop": 50,
        "display_port": 8099,
        "monitor_metric_curves": false,
        "monitor_report": false,
        "monitor_image": false
    },
    "optim": {
        "loss_fn": "lm",
        "optim": "Adam",
        "lr_en": 1e-5,
        "lr_de": 1e-5,
        "weight_decay": 5e-5,
        "lr_new": 5e-5,
        "amsgrad": true,
        "lr_scheduler": "StepLR",
        "step_size": 50,
        "gamma": 0.1
    },
    "other": {
        "task_name": "finetune_dymes_iuxray",
        "seed": -1,
        "cuda": 0,
        "task": "inference",
        "load_model_path": "results/iu_xray/dymes_4/model_best.pth",
        "resume": ""
    }
}