{
  "data": {
    "dataset_name": "mimic_cxr",
    "image_dir": "data/mimic_cxr/images",
    "ann_path": "data/mimic_cxr/annotation.json",
    "tokenizer": "mix",
    "max_seq_length": 90,
    "threshold": 10,
    "num_workers": 2,
    "batch_size": 16
  },
  "model": {
    "model": "dymes",
    "embed_dim": 512,
    "v_causal": "n",
    "causal_proj": false,
    "num_heads": 8,
    "en_num_layers": 6,
    "de_num_layers": 6,
    "dropout": 0.1,
    "logit_layers": 1,
    "bos_idx": 0,
    "eos_idx": 0,
    "pad_idx": 0,
    "use_bn": 0,
    "drop_prob_lm": 0.5,

    "enable": true,
    "use_confounder": true,
    "K": 6,
    "alpha_micro": 0.5,
    "use_backward_net": true,
    "ctx_tokens": 4,
    "x_dim": 512,
    "pmi_matrix_path": "pretrain/mimic_cxr/pmi_matrix_mimic_cxr.pt",
    "disease_corr_path": "pretrain/mimic_cxr/disease_corr_mimic_cxr.npy",
    "normal_template_path": "pretrain/mimic_cxr/normal_template_mimic_cxr.npy",
    "lambda_cem": 0.05,
    "lambda_back": 0.05,
    "lambda_cf": 0.03,
    "lambda_fd_ortho": 0.006,
    "cem_proj_dim": 256,
    "cem_nuclear_norm_mode": "bounded_fro",
    "cem_schatten_p": 1.0,
    "cem_svd_lowrank_q": 32,
    "cem_use_sv_entropy": false,
    "cem_sv_entropy_weight": 0.7,
    "cem_adaptive_lambda_ent": true,
    "cem_lambda_ent": 0.05,
    "enable_chi": true,
    "grid_hw": 32,
    "chi_save_every": 500,
    "chi_cmap": "jet",
    "chi_save_dir": "",
    "vis_upscale": 2,
    "vis_every": 5,
    "vis_grad_every": 0
  },
  "sample": {
    "sample_method": "beam_search",
    "length_penalty": "",
    "diversity_lambda": 0.5,
    "suppress_UNK": 0,
    "beam_size": 3,
    "temperature": 1.0,
    "sample_n": 1,
    "group_size": 1,
    "output_logsoftmax": 1,
    "decoding_constraint": 0,
    "block_trigrams": 1
  },
  "trainer": {
    "epochs": 40,
    "result_dir": "results/mimic_cxr/dymes_5",
    "record_dir": "results/mimic_cxr/dymes_5",
    "save_period": 1,
    "monitor_mode": "max",
    "monitor_metric": "BLEU_4",
    "early_stop": 40,
    "display_port": 8100,
    "monitor_metric_curves": false,
    "monitor_report": false,
    "monitor_image": false
  },
  "optim": {
    "loss_fn": "lm",
    "optim": "Adam",
    "lr_en": 1e-5,
    "lr_de": 1.5e-5,
    "weight_decay": 5e-5,
    "lr_new": 3e-5,
    "amsgrad": true,
    "lr_scheduler": "StepLR",
    "step_size": 30,
    "gamma": 0.1
  },
  "other": {
    "task_name": "finetune_dymes_mimic",
    "seed": -1,
    "cuda": 0,
    "task": "inference",
    "load_model_path": "results/mimic_cxr/dymes_5/model_best.pth",
    "resume": ""
  }
}
